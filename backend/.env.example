# Django
DEBUG=False
SECRET_KEY=change-me-generate-a-50-char-random-string
ALLOWED_HOSTS=.railway.app,localhost,127.0.0.1

# Database (Railway Postgres auto-injects DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis (optional; Railway Redis plugin auto-injects REDIS_URL)
REDIS_URL=redis://localhost:6379/0

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app,https://your-backend.up.railway.app

# HTTPS redirect (set False if Railway healthchecks fail)
SECURE_SSL_REDIRECT=True

# Gunicorn tuning
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
TWILIO_WEBHOOK_BASE_URL=
